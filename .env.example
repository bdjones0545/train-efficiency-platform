# TrainEfficiency — environment variables
#
# Copy to `.env` for local development and fill in real values, OR set these in
# the deployment environment (Replit Secrets) for production. NEVER commit real
# secret values to source control.
#
# In production (NODE_ENV=production) the app FAILS CLOSED at startup if any
# secret marked [REQUIRED IN PROD] is missing (see server/lib/secrets.ts).

# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@host:5432/dbname   # [REQUIRED] Postgres connection string
NODE_ENV=development                                      # development | production
PORT=5000

# ── Secrets (fail closed in production) ───────────────────────────────────────
# Signs sessions and OAuth-state HMACs. Use a long random string.
#   e.g. `openssl rand -hex 32`
SESSION_SECRET=                                           # [REQUIRED IN PROD]

# Encrypts stored third-party integration credentials (Gmail/Slack/Calendar) in
# the credentials vault (AES-256-GCM). MUST be at least 32 chars and MUST be a
# DIFFERENT value from SESSION_SECRET. Rotating this makes previously stored
# credentials undecryptable, so keep it stable (or plan a re-encryption).
#   e.g. `openssl rand -hex 32`
CREDENTIAL_ENCRYPTION_KEY=                                # [REQUIRED IN PROD]

# Gates admin "repair" endpoints via the x-admin-key header. Was previously
# committed in .replit — rotate and set here / in Secrets only. If unset, the
# repair endpoints deny all access (fail closed).
ADMIN_REPAIR_KEY=

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MARKETPLACE_WEBHOOK_SECRET=

# ── AI ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── Email / SMS ───────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_INBOUND_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Integrations ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
COMPOSIO_API_KEY=
AGENTMAIL_API_KEY=
AGENTMAIL_WEBHOOK_SECRET=
META_CAPI_TOKEN=
META_BOOK_ACCESS_TOKEN=

# ── TrainChat cross-platform API ──────────────────────────────────────────────
TRAINCHAT_API_KEY=
TRAINCHAT_API_BASE_URL=

# ── Background jobs ───────────────────────────────────────────────────────────
# Enables the durable, idempotent workflow job queue (recommended in production).
USE_WORKFLOW_JOB_QUEUE=false

# ── Automation safety ─────────────────────────────────────────────────────────
# Global emergency off-switch for AUTOMATED OUTREACH email sends (the guarded
# outbound-email chain used by cron/agent paths). Set to exactly "false" or "0"
# to halt all automated outreach without a code deploy; unset (or any other
# value) leaves sends ENABLED — the default behavior. Transactional emails
# (booking confirmations, reminders, receipts) are sent via a separate path and
# are intentionally NOT affected by this switch.
AUTOMATION_SENDS_ENABLED=
